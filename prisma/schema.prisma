generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SystemRole {
  USER
  ADMIN
}

model User {
  /// Primary key (auto-incremented)
  id Int @id @default(autoincrement())

  /// Unique email to prevent duplicate users
  email String @unique

  name    String
  surname String

  /// Optional avatar image URL
  avatarUrl String?

  /// Cloudinary public_id for deletes (no URL parsing)
  avatarPublicId String?

  /// Global system role (not group-specific)
  systemRole SystemRole @default(USER)

  /// Groups that the user is a member of
  memberships GroupMember[]

  /// Comments written by this user
  comments Comment[]

  /// Tasks assigned to this user
  taskAssignments TaskAssignee[]

  /// Record creation timestamp
  createdAt DateTime @default(now())

  /// Automatically updated on record change
  updatedAt DateTime @updatedAt

  /// Record deletion timestamp
  deletedAt DateTime?
}

model StudyGroup {
  /// Primary key
  id Int @id @default(autoincrement())

  /// Group name
  name String

  /// Optional description
  description String?

  /// Optional avatar image
  avatarUrl String?

  /// Cloudinary public_id for deletes (no URL parsing)
  avatarPublicId String?

  /// Relation to GroupMember (users in this group) this is junction table
  members GroupMember[]

  /// Tasks that belong to this study group
  tasks Task[]

  /// Record creation timestamp
  createdAt DateTime @default(now())

  /// Automatically updated on change
  updatedAt DateTime @updatedAt

  /// Record deletion timestamp
  deletedAt DateTime?
}

model GroupMember {
  /// Foreign key to User
  userId Int

  /// Foreign key to StudyGroup
  studyGroupId Int

  /// Role within the group
  role GroupRole @default(MEMBER)

  /// When the user joined the group
  joinedAt DateTime @default(now())

  /// Relation to User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Relation to StudyGroup 
  studyGroup StudyGroup @relation(fields: [studyGroupId], references: [id], onDelete: Cascade)

  /// Prevent duplicate membership (same user cannot join same group twice)
  @@unique([userId, studyGroupId])
  /// Indexes for performance
  @@index([userId])
  @@index([studyGroupId])
}

/// Role of a user within a study group
enum GroupRole {
  ADMIN
  MEMBER
}

model Task {
  /// Primary key (auto-incremented)
  id Int @id @default(autoincrement())

  title       String
  description String?
  dueDate     DateTime?

  /// If null, this task can be treated as a personal task
  studyGroupId Int?

  /// Relation to StudyGroup
  studyGroup StudyGroup? @relation(fields: [studyGroupId], references: [id], onDelete: Cascade)

  assignees TaskAssignee[]

  /// Comments on this task
  comments  Comment[]
  /// Record creation timestamp
  createdAt DateTime  @default(now())

  /// Automatically updated on record change
  updatedAt DateTime @updatedAt

  @@index([studyGroupId])

  /// Record deletion timestamp
  deletedAt DateTime?
}

model TaskAssignee {
  /// Foreign key to User
  userId Int

  /// Foreign key to Task
  taskId Int

  /// When the task was assigned
  assignedAt DateTime @default(now())

  /// Relation to User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Relation to Task
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// Prevent assigning the same task to the same user more than once
  @@unique([taskId, userId])
  /// Indexes for performance
  @@index([taskId])
  @@index([userId])
}

model Comment {
  id     Int @id @default(autoincrement())
  /// Foreign key to Task
  taskId Int
  /// Foreign key to User
  userId Int

  /// Optional parent comment id for replies
  parentId Int?

  /// Comment content
  content String

  /// Relation to Task
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// Relation to User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Parent comment relation
  parent Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)

  /// Replies of this comment
  replies Comment[] @relation("CommentReplies")

  /// Record creation timestamp
  createdAt DateTime @default(now())

  /// Automatically updated on record change
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([userId])
  @@index([parentId])

  /// Record deletion timestamp
  deletedAt DateTime?
}

/// Notes : cannot define another model in current model
/// If a relationship contains additional fields (e.g. role, joinedAt),
/// do NOT create a direct relation between the models.
/// Instead, use a junction (intermediate) table.
///
/// Example:
/// User ↔ StudyGroup (N-N) → use GroupMember
///
/// This allows storing extra data about the relationship itself,
/// such as the user's role within a specific group.

/// CASCADE DELETE EXPLANATION:
/// If the related parent record (User or StudyGroup) is deleted,
/// all associated GroupMember records will be automatically removed.
/// 
/// This prevents orphan records and keeps data integrity consistent.
/// 
/// Example:
/// - If a User is deleted → their group memberships are also deleted
/// - If a StudyGroup is deleted → all its members are also removed

/// SELF RELATION EXPLANATION:
/// A self relation is when a model references itself.
///
/// In this case:
/// - A Comment can have a parent Comment
/// - A Comment can have many replies
///
/// This is used to represent hierarchical or nested data structures,
/// such as comment threads.
///
/// How it works:
/// - parentId → points to another Comment (optional)
/// - parent   → the comment being replied to
/// - replies  → list of comments replying to this comment
///
/// Rules:
/// - parentId = null → top-level comment
/// - parentId != null → reply to another comment
///
/// Important:
/// Self relations require a named relation (e.g. "CommentReplies")
/// so Prisma can distinguish between the two sides of the relation.
